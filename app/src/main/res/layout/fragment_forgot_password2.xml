<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ── Soft top accent bar ── -->
    <View
        android:id="@+id/topAccent"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="#1D9E75"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Back button ── -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="68dp"
        android:layout_height="66dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/circle_bg_light"
        android:contentDescription="Go back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAccent" />

    <!-- ── Lock icon ── -->
    <ImageView
        android:id="@+id/ivLockIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="72dp"
        android:src="@drawable/ic_lock_reset"
        android:contentDescription="Reset password"
        android:padding="14dp"
        android:background="@drawable/circle_bg_teal"
        app:layout_constraintTop_toBottomOf="@id/topAccent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Headline ── -->
    <TextView
        android:id="@+id/tvHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Forgot password?"
        android:textColor="#2C2C2A"
        android:textSize="26sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.01"
        app:layout_constraintTop_toBottomOf="@id/ivLockIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Subtitle ── -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Enter your email and we'll send you a link to reset your password."
        android:textColor="#888780"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        android:fontFamily="sans-serif"
        app:layout_constraintTop_toBottomOf="@id/tvHeadline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Email input card ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#F6F5F2"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mail"
                android:alpha="0.45"
                android:contentDescription="Email icon" />

            <EditText
                android:id="@+id/etEmailForgot"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="your@email.com"
                android:inputType="textEmailAddress"
                android:textSize="15sp"
                android:textColor="#2C2C2A"
                android:textColorHint="#B4B2A9"
                android:fontFamily="sans-serif"
                android:imeOptions="actionDone"
                android:singleLine="true" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Email format hint ── -->
    <TextView
        android:id="@+id/tvEmailHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp"
        android:text="We'll only send a link if this email is registered."
        android:textColor="#B4B2A9"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        app:layout_constraintTop_toBottomOf="@id/cardEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Send reset button ── -->
    <Button
        android:id="@+id/btnResetForgot"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="28dp"
        android:text="Send reset link"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#1D9E75"
        android:stateListAnimator="@null"
        style="?attr/materialButtonStyle"
        app:cornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvEmailHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Divider row ── -->
    <LinearLayout
        android:id="@+id/dividerRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/btnResetForgot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#E8E6E0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="or"
            android:textColor="#B4B2A9"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:fontFamily="sans-serif" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#E8E6E0" />

    </LinearLayout>

    <!-- ── Back to login link ── -->
    <TextView
        android:id="@+id/tvBackToLogin"
        android:layout_width="216dp"
        android:layout_height="64dp"
        android:layout_marginTop="60dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif-medium"
        android:text="Back to sign in"
        android:textColor="#1D9E75"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.769"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dividerRow" />

</androidx.constraintlayout.widget.ConstraintLayout>