<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingHorizontal="28dp"
    android:gravity="center_vertical">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="69dp"
        android:layout_height="70dp"
        android:layout_marginBottom="32dp"
        android:background="@null"
        android:contentDescription="Back"
        android:src="@drawable/ic_arrow_back" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RESET\nPASSWORD."
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.02"
        android:lineSpacingMultiplier="1.1"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter your email and we'll send you a link to get back into your account."
        android:textColor="#888888"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="36dp" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EMAIL" android:textColor="#888888" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.12" android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etEmailForgot"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/input_bg_dark"
        android:paddingHorizontal="16dp"
        android:hint="you@email.com"
        android:textColorHint="#444444"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:inputType="textEmailAddress"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btnResetForgot"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SEND RESET LINK"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.10"
        android:backgroundTint="#FFFFFF"
        android:stateListAnimator="@null"
        style="?attr/materialButtonStyle"
        app:cornerRadius="4dp" />

</LinearLayout>