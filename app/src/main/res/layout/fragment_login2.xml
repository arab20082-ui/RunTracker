<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingHorizontal="28dp"
    android:gravity="center_vertical">

    <!-- LOGO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.08"
        android:text="RunTracker"
        android:textColor="#FFFFFF"
        android:textSize="36sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WELCOME BACK."
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.04"
        android:layout_marginBottom="36dp" />

    <!-- EMAIL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMAIL"
        android:textColor="#888888"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etUsernameLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/input_bg_dark"
        android:paddingHorizontal="16dp"
        android:hint="you@email.com"
        android:textColorHint="#444444"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:inputType="textEmailAddress"
        android:imeOptions="actionNext"
        android:singleLine="true"
        android:layout_marginBottom="20dp" />

    <!-- PASSWORD -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PASSWORD"
        android:textColor="#888888"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etPasswordLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/input_bg_dark"
        android:paddingHorizontal="16dp"
        android:hint="••••••••"
        android:textColorHint="#444444"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:inputType="textPassword"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:layout_marginBottom="12dp" />

    <!-- FORGOT -->
    <TextView
        android:id="@+id/tvForgotPasswordLogin"
        android:layout_width="243dp"
        android:layout_height="70dp"
        android:layout_gravity="end"
        android:layout_marginBottom="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="sans-serif"
        android:text="Forgot password?"
        android:textColor="#888888"
        android:textSize="13sp" />

    <!-- SIGN IN BUTTON -->
    <Button
        android:id="@+id/btnLoginLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SIGN IN"
        android:textColor="#000000"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.10"
        android:backgroundTint="#FFFFFF"
        android:stateListAnimator="@null"
        style="?attr/materialButtonStyle"
        app:cornerRadius="4dp"
        android:layout_marginBottom="20dp" />

    <!-- DIVIDER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#333333" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  OR  " android:textColor="#555555" android:textSize="12sp" android:fontFamily="sans-serif" />
        <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#333333" />
    </LinearLayout>

    <!-- CREATE ACCOUNT -->
    <Button
        android:id="@+id/tvSignupLinkLogin"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="CREATE ACCOUNT"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.10"
        android:backgroundTint="#1A1A1A"
        android:stateListAnimator="@null"
        style="?attr/materialButtonStyle"
        app:cornerRadius="4dp" />

</LinearLayout>