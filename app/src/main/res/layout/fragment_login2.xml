<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ── Top accent bar ── -->
    <View
        android:id="@+id/topAccent"
        android:layout_width="0dp"
        android:layout_height="4dp"
        android:background="#2C2C2A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Scrollable body ── -->
    <ScrollView
        android:id="@+id/scrollBody"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/topAccent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingBottom="40dp">

            <!-- ── Brand mark / logo ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="56dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circle_bg_dark"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_run_shoe"
                        android:contentDescription="App logo" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RunTrack"
                    android:textColor="#2C2C2A"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="14dp" />

            </LinearLayout>

            <!-- ── Section heading ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back"
                android:textColor="#2C2C2A"
                android:textSize="26sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="28dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue tracking your runs."
                android:textColor="#888780"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp" />

            <!-- ── Email field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#5F5E5A"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#F6F5F2"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_mail"
                        android:alpha="0.4"
                        android:contentDescription="Email icon" />

                    <EditText
                        android:id="@+id/etUsernameLogin"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="your@email.com"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:textColor="#2C2C2A"
                        android:textColorHint="#B4B2A9"
                        android:fontFamily="sans-serif"
                        android:imeOptions="actionNext"
                        android:singleLine="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Password field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textColor="#5F5E5A"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F6F5F2"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock"
                        android:alpha="0.4"
                        android:contentDescription="Password icon" />

                    <EditText
                        android:id="@+id/etPasswordLogin"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:textColor="#2C2C2A"
                        android:textColorHint="#B4B2A9"
                        android:fontFamily="sans-serif"
                        android:imeOptions="actionDone"
                        android:singleLine="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Forgot password link ── -->
            <TextView
                android:id="@+id/tvForgotPasswordLogin"
                android:layout_width="248dp"
                android:layout_height="54dp"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:text="Forgot password?"
                android:textColor="#1D9E75"
                android:textSize="13sp" />

            <!-- ── Login button ── -->
            <Button
                android:id="@+id/btnLoginLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Login"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="#2C2C2A"
                android:stateListAnimator="@null"
                style="?attr/materialButtonStyle"
                app:cornerRadius="16dp" />

            <!-- ── Divider ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E6E0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="no account yet?"
                    android:textColor="#B4B2A9"
                    android:textSize="12sp"
                    android:paddingHorizontal="14dp"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#E8E6E0" />

            </LinearLayout>

            <!-- ── Sign up link ── -->
            <Button
                android:id="@+id/tvSignupLinkLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Create an account"
                android:textColor="#2C2C2A"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="#F6F5F2"
                android:stateListAnimator="@null"
                style="?attr/materialButtonStyle"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>