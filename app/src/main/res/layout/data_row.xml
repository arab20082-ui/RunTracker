<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Top row: date + chevron ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_bg_sand"
                android:gravity="center">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_run_shoe"
                    android:contentDescription="Run" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDateRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="21 May 2025"
                android:textColor="#888780"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_right"
                android:alpha="0.25"
                android:contentDescription="View details" />

        </LinearLayout>

        <!-- ── Distance (hero number) ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvDistanceRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="8.4"
                android:textColor="#2C2C2A"
                android:textSize="40sp"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" km"
                android:textColor="#888780"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="7dp" />

        </LinearLayout>

        <!-- ── Divider ── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E8E6E0"
            android:layout_marginBottom="12dp" />

        <!-- ── Stats row: time / calories / pace / bpm ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4">

            <!-- Time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:text="time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B4B2A9"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvTimeRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="52:14"
                    android:textColor="#2C2C2A"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="0.5dp"
                android:layout_height="match_parent"
                android:background="#E8E6E0"
                android:layout_marginVertical="2dp" />

            <!-- Calories -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:text="kcal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B4B2A9"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvCaloriesRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="487"
                    android:textColor="#2C2C2A"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="0.5dp"
                android:layout_height="match_parent"
                android:background="#E8E6E0"
                android:layout_marginVertical="2dp" />

            <!-- Pace -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:text="pace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B4B2A9"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvPaceRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:13"
                    android:textColor="#1D9E75"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="0.5dp"
                android:layout_height="match_parent"
                android:background="#E8E6E0"
                android:layout_marginVertical="2dp" />

            <!-- BPM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:text="bpm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#B4B2A9"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvBPMRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="142"
                    android:textColor="#2C2C2A"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Streak badge (bottom) ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/tag_bg_sand"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_fire"
                android:contentDescription="Streak" />

            <TextView
                android:id="@+id/tvStreakRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 day streak"
                android:textColor="#5F5E5A"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="5dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>