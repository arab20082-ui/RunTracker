<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#000000"
    android:paddingHorizontal="24dp"
    android:paddingVertical="20dp"
    android:foreground="?attr/selectableItemBackground">

    <!-- DATE -->
    <TextView
        android:id="@+id/tvDateRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="21 May 2025"
        android:textColor="#555555"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.06"
        android:layout_marginBottom="6dp" />

    <!-- DISTANCE hero -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvDistanceRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8.42"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            android:fontFamily="sans-serif-black"
            android:includeFontPadding="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" km"
            android:textColor="#555555"
            android:textSize="18sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

    <!-- STATS row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="28dp">
            <TextView android:id="@+id/tvTimeRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="44:12" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="sans-serif-black" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TIME" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="74dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="28dp"
            android:orientation="vertical"
            tools:ignore="ExtraText">

            <TextView
                android:id="@+id/tvPaceRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5'15&quot;" android:textColor="#FFFFFF" android:textSize="18sp"
            android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.10"
                android:text="PACE"
                android:textColor="#555555"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="28dp">
            <TextView android:id="@+id/tvCaloriesRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="412" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="sans-serif-black" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KCAL" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvBPMRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="148" android:textColor="#FFFFFF" android:textSize="18sp" android:fontFamily="sans-serif-black" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BPM" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- STREAK + hidden tvStreakRow (kept for adapter) -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔥 " android:textSize="12sp" />
        <TextView android:id="@+id/tvStreakRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 day streak" android:textColor="#888888" android:textSize="12sp" android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- BOTTOM DIVIDER -->
    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#1A1A1A" android:layout_marginTop="20dp" />

</LinearLayout>