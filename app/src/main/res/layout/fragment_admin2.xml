<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F5F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══════════════════════════════════════ -->
        <!--          TOP HEADER BAR               -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="20dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Good morning,"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#888780"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:text="Dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2C2C2A"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Profile Card (tappable) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardUserProfile"
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8E6E0"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/imgUserProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user"
                    android:contentDescription="User profile" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--         QUICK STATS ROW               -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:weightSum="3">

            <!-- Stat: Total Runs -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:text="runs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:text="48"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat: Total KM -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:text="km total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:text="312"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stat: Streak -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:text="streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:text="12d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--         SECTION LABEL                 -->
        <!-- ══════════════════════════════════════ -->
        <TextView
            android:text="Actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B4B2A9"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:fontFamily="sans-serif-medium"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp" />

        <!-- ══════════════════════════════════════ -->
        <!--       PRIMARY ACTION: ADD RUN         -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#2C2C2A"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/btnAdd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_bg_light"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_add_run"
                        android:contentDescription="Add run icon" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:text="Log a new run"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:text="Track distance, pace &amp; calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:alpha="0.4"
                    android:contentDescription="Navigate" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--      SECONDARY ACTION: ALL RUNS       -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/btnAll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_bg_sand"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_list"
                        android:contentDescription="All runs icon" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:text="All runs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:text="Browse your run history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:alpha="0.25"
                    android:contentDescription="Navigate" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--      TERTIARY: USER PROFILE ROW       -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_bg_sand"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_user"
                        android:contentDescription="Profile icon" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:text="Your profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:text="Edit info, photo &amp; settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#888780"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif" />

                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right"
                    android:alpha="0.25"
                    android:contentDescription="Navigate" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--          MOTIVATIONAL FOOTER          -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:text="Every run counts."
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B4B2A9"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>