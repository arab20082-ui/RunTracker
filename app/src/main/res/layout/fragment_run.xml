<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <TextView android:id="@+id/tvRunStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="READY TO RUN" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.16" android:layout_marginTop="52dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tvRunTimer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#FFFFFF" android:textSize="88sp" android:fontFamily="sans-serif-light" android:includeFontPadding="false" android:layout_marginTop="4dp" app:layout_constraintTop_toBottomOf="@id/tvRunStatus" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tvDurLbl" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DURATION" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.16" app:layout_constraintTop_toBottomOf="@id/tvRunTimer" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <View android:id="@+id/div1" android:layout_width="0dp" android:layout_height="0.5dp" android:background="#1F1F1F" android:layout_marginTop="22dp" app:layout_constraintTop_toBottomOf="@id/tvDurLbl" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- DISTANCE / PACE / STEPS -->
    <LinearLayout android:id="@+id/statsRow" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginTop="26dp" app:layout_constraintTop_toBottomOf="@id/div1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvRunDistance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00" android:textColor="#FFFFFF" android:textSize="36sp" android:fontFamily="sans-serif-black" android:includeFontPadding="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KM" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="match_parent" android:background="#1F1F1F" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvRunPace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--:--" android:textColor="#FFFFFF" android:textSize="32sp" android:fontFamily="sans-serif-black" android:includeFontPadding="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AVG PACE" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="match_parent" android:background="#1F1F1F" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:id="@+id/tvRunSteps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="36sp" android:fontFamily="sans-serif-black" android:includeFontPadding="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STEPS" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginTop="3dp" />
        </LinearLayout>

    </LinearLayout>

    <View android:id="@+id/div2" android:layout_width="0dp" android:layout_height="0.5dp" android:background="#1F1F1F" android:layout_marginTop="26dp" app:layout_constraintTop_toBottomOf="@id/statsRow" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />

    <!-- CALORIES + BPM -->
    <LinearLayout android:id="@+id/cardsRow" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" app:layout_constraintTop_toBottomOf="@id/div2" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="20dp" android:background="#0D0D0D">
            <TextView android:id="@+id/tvRunCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textSize="30sp" android:fontFamily="sans-serif-black" android:includeFontPadding="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KCAL" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginTop="4dp" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="match_parent" android:background="#1F1F1F" />

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="20dp" android:background="#0D0D0D">
            <TextView android:id="@+id/tvRunBPM" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- bpm" android:textColor="#FFFFFF" android:textSize="24sp" android:fontFamily="sans-serif-black" android:includeFontPadding="false" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEART RATE" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- STREAK DISPLAY -->
    <TextView
        android:id="@+id/tvRunStreak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 day streak"
        android:textColor="#555555"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.06"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/cardsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BUTTONS -->
    <LinearLayout android:id="@+id/btnRow" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:paddingBottom="40dp" android:weightSum="2" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btnRunFinish" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_marginEnd="8dp" android:text="FINISH" android:textColor="#888888" android:textSize="13sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.10" android:backgroundTint="#1A1A1A" android:stateListAnimator="@null" style="?attr/materialButtonStyle" app:cornerRadius="4dp" />
        <Button android:id="@+id/btnRunStartStop" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:layout_marginStart="8dp" android:text="START" android:textColor="#000000" android:textSize="13sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.10" android:backgroundTint="#FFFFFF" android:stateListAnimator="@null" style="?attr/materialButtonStyle" app:cornerRadius="4dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>