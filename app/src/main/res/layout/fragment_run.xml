<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F5F2">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="120dp">

            <!-- ══════════════════════════════════ -->
            <!--            HEADER                 -->
            <!-- ══════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:paddingHorizontal="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="Log a run"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C2C2A"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:text="Fill in your run details below"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B4B2A9"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_bg_teal"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_run_shoe"
                        android:contentDescription="Run" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════ -->
            <!--        DISTANCE & TIME            -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:text="Distance &amp; time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B4B2A9"
                android:textSize="11sp"
                android:letterSpacing="0.10"
                android:fontFamily="sans-serif-medium"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp">

                    <!-- Distance -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_bg_teal"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/ic_route"
                                android:contentDescription="Distance" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:text="Distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#888780"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <EditText
                                android:id="@+id/etDistanceRun"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:layout_marginTop="1dp"
                                android:background="@null"
                                android:fontFamily="sans-serif-light"
                                android:hint="0.00"
                                android:imeOptions="actionNext"
                                android:inputType="numberDecimal"
                                android:singleLine="true"
                                android:textColor="#2C2C2A"
                                android:textColorHint="#D3D1C7"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <TextView
                            android:text="km"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B4B2A9"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E6E0" />

                    <!-- Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_bg_sand"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/ic_clock"
                                android:contentDescription="Time" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:text="Duration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#888780"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <EditText
                                android:id="@+id/etTimeRun"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:layout_marginTop="1dp"
                                android:background="@null"
                                android:fontFamily="sans-serif-light"
                                android:hint="00:00"
                                android:imeOptions="actionNext"
                                android:inputType="time"
                                android:singleLine="true"
                                android:textColor="#2C2C2A"
                                android:textColorHint="#D3D1C7"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <TextView
                            android:text="mm:ss"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B4B2A9"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════ -->
            <!--        BODY STATS                 -->
            <!-- ══════════════════════════════════ -->
            <TextView
                android:text="Body stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B4B2A9"
                android:textSize="11sp"
                android:letterSpacing="0.10"
                android:fontFamily="sans-serif-medium"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp">

                    <!-- Calories -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_bg_amber"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/ic_fire"
                                android:contentDescription="Calories" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:text="Calories burned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#888780"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <EditText
                                android:id="@+id/etCaloriesRun"
                                android:layout_width="match_parent"
                                android:layout_height="64dp"
                                android:layout_marginTop="1dp"
                                android:background="@null"
                                android:fontFamily="sans-serif-light"
                                android:hint="0"
                                android:imeOptions="actionNext"
                                android:inputType="numberSigned"
                                android:singleLine="true"
                                android:textColor="#2C2C2A"
                                android:textColorHint="#D3D1C7"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <TextView
                            android:text="kcal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B4B2A9"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E6E0" />

                    <!-- BPM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_bg_red"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:src="@drawable/ic_heart"
                                android:contentDescription="Heart rate" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:text="Heart rate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#888780"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif" />

                            <EditText
                                android:id="@+id/etBPMRun"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="1dp"
                                android:background="@null"
                                android:fontFamily="sans-serif-light"
                                android:hint="0"
                                android:imeOptions="actionNext"
                                android:inputType="numberSigned"
                                android:singleLine="true"
                                android:textColor="#2C2C2A"
                                android:textColorHint="#D3D1C7"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <TextView
                            android:text="bpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#B4B2A9"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E8E6E0" />

                    <!-- Streak -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="85dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_bg_purple"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="17dp"
                                android:layout_height="17dp"
                                android:contentDescription="Streak"
                                android:src="@drawable/ic_trophy" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:text="Streak"
                                android:textColor="#888780"
                                android:textSize="11sp" />

                            <EditText
                                android:id="@+id/etStreakRun"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:layout_marginTop="1dp"
                                android:background="@null"
                                android:fontFamily="sans-serif-light"
                                android:hint="0"
                                android:imeOptions="actionDone"
                                android:inputType="numberSigned"
                                android:singleLine="true"
                                android:textColor="#2C2C2A"
                                android:textColorHint="#D3D1C7"
                                android:textSize="22sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="days"
                            android:textColor="#B4B2A9"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════ -->
    <!--        FLOATING SAVE BUTTON           -->
    <!-- ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F6F5F2"
        android:padding="20dp"
        android:layout_gravity="bottom">

        <Button
            android:id="@+id/btnSaveRun"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save run"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="#1D9E75"
            android:stateListAnimator="@null"
            style="?attr/materialButtonStyle"
            app:cornerRadius="16dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>