<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000000"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVITY"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:layout_marginBottom="16dp" />

        <!-- Search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg_dark"
            android:paddingHorizontal="14dp">

            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_search" android:alpha="0.4" android:contentDescription="Search" />

            <SearchView
                android:id="@+id/srchViewRun"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:queryHint="Search runs..."
                android:iconifiedByDefault="false"
                android:maxWidth="9999dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRunlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingBottom="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NO RUNS YET."
            android:textColor="#333333"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start your first run to see it here."
            android:textColor="#444444"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</LinearLayout>