<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- HEADER -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:paddingTop="52dp" android:paddingBottom="28dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="EDIT PROFILE" android:textColor="#FFFFFF" android:textSize="22sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- AVATAR -->
            <FrameLayout android:layout_width="88dp" android:layout_height="88dp" android:layout_gravity="center_horizontal" android:layout_marginBottom="32dp">
                <androidx.cardview.widget.CardView android:layout_width="88dp" android:layout_height="88dp" app:cardCornerRadius="44dp" app:cardElevation="0dp" app:cardBackgroundColor="#1A1A1A">
                    <ImageView android:id="@+id/ivProfileImageEdit" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/ic_user" android:contentDescription="Photo" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackgroundBorderless" />
                </androidx.cardview.widget.CardView>
                <LinearLayout android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="bottom|end" android:background="@drawable/circle_bg_white" android:gravity="center">
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_camera" android:contentDescription="Change" />
                </LinearLayout>
            </FrameLayout>

            <!-- PERSONAL INFO -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERSONAL INFO" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginHorizontal="24dp" android:layout_marginBottom="12dp" />
            <EditText android:id="@+id/etFirstNameProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="First name" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPersonName" android:imeOptions="actionNext" android:singleLine="true" />
            <EditText android:id="@+id/etLastNameProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Last name" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPersonName" android:imeOptions="actionNext" android:singleLine="true" />
            <EditText android:id="@+id/etPhoneProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Phone number" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="phone" android:imeOptions="actionNext" android:singleLine="true" />
            <EditText android:id="@+id/etAddressProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="24dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Address" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPostalAddress" android:imeOptions="actionNext" android:singleLine="true" />

            <!-- FITNESS STATS -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FITNESS STATS" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginHorizontal="24dp" android:layout_marginBottom="12dp" />

            <!-- Weight + Height row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:weightSum="2">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WEIGHT (KG)" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginBottom="4dp" />
                    <EditText android:id="@+id/etWeightProfile" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="70" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="numberDecimal" android:imeOptions="actionNext" android:singleLine="true" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HEIGHT (CM)" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginBottom="4dp" />
                    <EditText android:id="@+id/etHeightProfile" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="170" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="number" android:imeOptions="actionNext" android:singleLine="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Age -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginHorizontal="24dp" android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AGE" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.10" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/etAgeProfile" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="25" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="number" android:imeOptions="actionNext" android:singleLine="true" />
            </LinearLayout>

            <!-- ACCOUNT -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACCOUNT" android:textColor="#444444" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginHorizontal="24dp" android:layout_marginBottom="12dp" />
            <EditText android:id="@+id/etEmailProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Email address" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textEmailAddress" android:imeOptions="actionNext" android:singleLine="true" />
            <EditText android:id="@+id/etPasswordProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:layout_marginBottom="10dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="New password (optional)" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionNext" android:singleLine="true" />
            <EditText android:id="@+id/etConfirmPasswordProfile" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="24dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Confirm new password" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionDone" android:singleLine="true" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- SAVE BUTTON -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#000000" android:padding="24dp" android:layout_gravity="bottom">
        <Button android:id="@+id/btnUpdateProfile" android:layout_width="match_parent" android:layout_height="56dp" android:text="SAVE CHANGES" android:textColor="#000000" android:textSize="13sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.10" android:backgroundTint="#FFFFFF" android:stateListAnimator="@null" style="?attr/materialButtonStyle" app:cornerRadius="4dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>