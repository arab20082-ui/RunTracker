<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F5F2"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ══════════════════════════════════════ -->
        <!--            HERO BAND                  -->
        <!-- ══════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <!-- Background run photo -->
            <ImageView
                android:id="@+id/ivRunHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/run_hero_photo"
                android:contentDescription="Run photo" />

            <!-- Dark overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_hero_overlay" />

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btnBackDetail"
                android:layout_width="55dp"
                android:layout_height="60dp"
                android:layout_margin="16dp"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="Back"
                android:elevation="4dp"
                android:src="@drawable/ic_arrow_back" />

            <!-- Date tag top-right -->
            <TextView
                android:id="@+id/tvRunDateDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/tag_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Today · Morning run"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:elevation="4dp" />

            <!-- Hero distance label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingBottom="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR RUN"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.14" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/tvDistanceDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.4"
                        android:textColor="#FFFFFF"
                        android:textSize="54sp"
                        android:fontFamily="sans-serif-light"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" KM"
                        android:textColor="#B3FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="11dp" />

                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════════════ -->
        <!--         STATS SECTION                 -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:text="Statistics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B4B2A9"
                android:textSize="11sp"
                android:letterSpacing="0.10"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="14dp" />

            <!-- Row 1: Time + Calories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <!-- Time card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="#F6F5F2"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_clock" android:alpha="0.45" android:contentDescription="Time" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Duration" android:textColor="#888780" android:textSize="11sp" android:fontFamily="sans-serif" android:layout_marginStart="6dp" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvTimeDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="52:14" android:textColor="#2C2C2A" android:textSize="26sp" android:fontFamily="sans-serif-light" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Calories card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="#FFF8F0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_fire" android:alpha="0.55" android:contentDescription="Calories" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calories" android:textColor="#888780" android:textSize="11sp" android:fontFamily="sans-serif" android:layout_marginStart="6dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom">
                            <TextView android:id="@+id/tvCaloriesDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="487" android:textColor="#BA7517" android:textSize="26sp" android:fontFamily="sans-serif-light" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" kcal" android:textColor="#EF9F27" android:textSize="12sp" android:fontFamily="sans-serif" android:layout_marginBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Row 2: Pace + BPM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="10dp">

                <!-- Pace card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="#F0FBF6"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_bolt" android:alpha="0.55" android:contentDescription="Pace" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg. pace" android:textColor="#888780" android:textSize="11sp" android:fontFamily="sans-serif" android:layout_marginStart="6dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom">
                            <TextView android:id="@+id/tvPaceDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6:13" android:textColor="#0F6E56" android:textSize="26sp" android:fontFamily="sans-serif-light" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" /km" android:textColor="#1D9E75" android:textSize="12sp" android:fontFamily="sans-serif" android:layout_marginBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BPM card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="#FEF0F0"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_heart" android:alpha="0.55" android:contentDescription="Heart rate" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Heart rate" android:textColor="#888780" android:textSize="11sp" android:fontFamily="sans-serif" android:layout_marginStart="6dp" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom">
                            <TextView android:id="@+id/tvBPMDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="142" android:textColor="#A32D2D" android:textSize="26sp" android:fontFamily="sans-serif-light" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" bpm" android:textColor="#E24B4A" android:textSize="12sp" android:fontFamily="sans-serif" android:layout_marginBottom="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--         STREAK BANNER                 -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#EEEDFE"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_bg_purple"
                    android:gravity="center">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_trophy" android:contentDescription="Streak" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active streak"
                        android:textColor="#7F77DD"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tvStreakDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="#3C3489"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" days in a row"
                            android:textColor="#534AB7"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:layout_marginBottom="5dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--         SHARE BUTTON                  -->
        <!-- ══════════════════════════════════════ -->
        <Button
            android:id="@+id/btnShareRun"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:text="Share this run"
            android:textColor="#2C2C2A"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="#FFFFFF"
            android:stateListAnimator="@null"
            style="?attr/materialButtonStyle"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>