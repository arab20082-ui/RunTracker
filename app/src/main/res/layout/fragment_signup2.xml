<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOIN THE\nMOVEMENT."
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="32dp" />

        <!-- PERSONAL INFO label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERSONAL INFO" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etFirstNameSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="First name" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPersonName" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/etLastNameSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Last name" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPersonName" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/etPhoneSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Phone number" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="phone" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/etAddressSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Address" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPostalAddress" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="24dp" />

        <!-- ACCOUNT label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACCOUNT" android:textColor="#555555" android:textSize="10sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.14" android:layout_marginBottom="12dp" />

        <EditText android:id="@+id/etEmailSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Email address" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textEmailAddress" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/etPasswordSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Password" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionNext" android:singleLine="true" android:layout_marginBottom="10dp" />
        <EditText android:id="@+id/etConfirmPasswordSignup" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg_dark" android:paddingHorizontal="16dp" android:hint="Confirm password" android:textColorHint="#444444" android:textColor="#FFFFFF" android:textSize="15sp" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionDone" android:singleLine="true" android:layout_marginBottom="32dp" />

        <Button android:id="@+id/btnSignup" android:layout_width="match_parent" android:layout_height="56dp" android:text="CREATE ACCOUNT" android:textColor="#000000" android:textSize="14sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.10" android:backgroundTint="#FFFFFF" android:stateListAnimator="@null" style="?attr/materialButtonStyle" app:cornerRadius="4dp" android:layout_marginBottom="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#333333" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  ALREADY A MEMBER?  " android:textColor="#555555" android:textSize="11sp" android:fontFamily="sans-serif" />
            <View android:layout_width="0dp" android:layout_height="0.5dp" android:layout_weight="1" android:background="#333333" />
        </LinearLayout>

        <Button android:id="@+id/tvLoginLinkSignup" android:layout_width="match_parent" android:layout_height="52dp" android:text="SIGN IN" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.10" android:backgroundTint="#1A1A1A" android:stateListAnimator="@null" style="?attr/materialButtonStyle" app:cornerRadius="4dp" />

    </LinearLayout>
</ScrollView>